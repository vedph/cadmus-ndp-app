{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "outDir": "../../../out-tsc/lib",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.spec.ts"
  ],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
